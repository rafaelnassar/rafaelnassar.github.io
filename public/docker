# Rafael Nassar Docker Hub
# Usage:
#   irm https://rafaelnassar.github.io/docker | iex

$ErrorActionPreference = 'Stop'

try {
  [Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12
} catch {}

$BaseUrl = 'https://rafaelnassar.github.io'
$ManifestUrl = "$BaseUrl/tools/docker-tools.json"
$InstallRoot = Join-Path $HOME 'RafaelDockerTools'
$CacheDir = Join-Path $InstallRoot 'cache'

function Say {
  param(
    [string]$Text,
    [ConsoleColor]$Color = [ConsoleColor]::Gray
  )

  try {
    Write-Host $Text -ForegroundColor $Color
  } catch {
    Write-Host $Text
  }
}

function Header {
  Clear-Host
  Write-Host ''
  Say '======================================================' Cyan
  Say '              RAFAEL NASSAR - DOCKER HUB              ' Cyan
  Say '              Docker tools interactive menu            ' Cyan
  Say '======================================================' Cyan
  Write-Host ''
}

function Pause-Menu {
  Write-Host ''
  Read-Host 'Press ENTER to continue'
}

function Ensure-Dirs {
  New-Item -ItemType Directory -Path $InstallRoot -Force | Out-Null
  New-Item -ItemType Directory -Path $CacheDir -Force | Out-Null
}

function Get-ToolManifest {
  Say 'Loading tools catalog...' Blue

  try {
    $manifest = Invoke-RestMethod -Uri $ManifestUrl -UseBasicParsing
    if (-not $manifest.tools -or $manifest.tools.Count -eq 0) {
      throw 'Empty manifest.'
    }

    return $manifest
  } catch {
    throw "Could not load catalog: $ManifestUrl"
  }
}

function Resolve-ToolUrl {
  param([string]$Url)

  if ($Url -match '^https?://') {
    return $Url
  }

  if ($Url.StartsWith('/')) {
    return "$BaseUrl$Url"
  }

  return "$BaseUrl/$Url"
}

function Invoke-RemoteInstaller {
  param(
    [Parameter(Mandatory = $true)]$Tool
  )

  $scriptUrl = Resolve-ToolUrl $Tool.script
  $safeId = "$($Tool.id)" -replace '[^a-zA-Z0-9_-]', '-'
  $localScript = Join-Path $CacheDir "$safeId.ps1"

  Header
  Say "Tool: $($Tool.name)" White

  if ($Tool.description) {
    Write-Host "$($Tool.description)"
  }

  Write-Host ''
  Say 'Source:' Yellow
  Write-Host "  $scriptUrl"
  Write-Host ''

  $confirm = Read-Host 'Run this installer? [Y/n]'

  if ($confirm -match '^[nN]') {
    Say 'Canceled.' Yellow
    return
  }

  Say 'Downloading installer...' Blue
  Invoke-WebRequest -Uri $scriptUrl -UseBasicParsing -OutFile $localScript

  Say 'Running installer...' Blue
  & powershell -NoProfile -ExecutionPolicy Bypass -File $localScript

  Say 'Done.' Green
}

function MainMenu {
  while ($true) {
    $manifest = Get-ToolManifest

    Header
    Say 'Choose a tool:' White
    Write-Host ''

    $tools = @($manifest.tools)

    for ($i = 0; $i -lt $tools.Count; $i++) {
      $n = $i + 1
      $tool = $tools[$i]

      Write-Host ("  [{0}] {1}" -f $n, $tool.name)

      if ($tool.description) {
        Write-Host ("      {0}" -f $tool.description)
      }
    }

    Write-Host ''
    Write-Host '  [A] Reload catalog'
    Write-Host '  [0] Exit'
    Write-Host ''

    $op = Read-Host 'Option'

    if ($op -eq '0') {
      return
    }

    if ($op -match '^[aA]$') {
      continue
    }

    $index = 0

    if ([int]::TryParse($op, [ref]$index)) {
      if ($index -ge 1 -and $index -le $tools.Count) {
        Invoke-RemoteInstaller -Tool $tools[$index - 1]
        Pause-Menu
        continue
      }
    }

    Say 'Invalid option.' Yellow
    Start-Sleep -Seconds 1
  }
}

try {
  Ensure-Dirs
  MainMenu
} catch {
  Write-Host ''
  Say "ERROR: $($_.Exception.Message)" Red
  Write-Host ''
  Pause-Menu
  exit 1
}
